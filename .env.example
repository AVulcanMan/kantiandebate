# Copy relevant lines into your environment or a local secret.txt (untracked).
# KDS reads these from the environment; secret.txt is loaded automatically if present.

# --- LLM provider (default: groq) ---
GROQ_API_KEY=your-groq-key-here
TOGETHER_API_KEY=your-together-key-here

# Provider/model overrides (optional; defaults live in kds/config.py)
KDS_PROVIDER=groq
# KDS_MODEL=llama-3.3-70b-versatile
# KDS_TEMPERATURE=0.7
# KDS_MAX_TOKENS=1024

# --- ASR backend for the footage pipeline ---
# groq_whisper (hosted fallback) | collaborator (GPU fleet tooling)
KDS_ASR_BACKEND=groq_whisper
